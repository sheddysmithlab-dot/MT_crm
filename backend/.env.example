# Malwa CRM API — copy to .env and fill values
APP_NAME=Malwa CRM API
APP_ENV=development
DEBUG=true
API_PREFIX=/api

# MySQL — Hostinger example (use YOUR db name from hPanel, not malwa_crm):
# DATABASE_URL=mysql+pymysql://u808821982_Malwa_crm:YOUR_PASSWORD@127.0.0.1:3306/u808821982_Malwa_crm?charset=utf8mb4
# Local:
DATABASE_URL=mysql+pymysql://crm_user:CHANGE_ME@127.0.0.1:3306/malwa_crm?charset=utf8mb4

# JWT — generate a long random string for production
JWT_SECRET=change-me-to-a-long-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://crm.malwatrolley.com

# Seed admin (scripts/seed_admin.py) — change after first login
SEED_ADMIN_EMAIL=admin@malwatrolley.com
SEED_ADMIN_PASSWORD=ChangeMe822!
SEED_ADMIN_NAME=Malwa Admin
