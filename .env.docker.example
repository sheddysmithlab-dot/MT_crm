# Copy to .env.docker / Hostinger Compose Environment and fill passwords

HTTP_PORT=80
MTCRM_API_PORT=8010

# Frontend (File Manager) talks via api-bridge → VPS:8010
VITE_API_URL=https://crm.malwatrolley.com/api

# ---- Hostinger hPanel MySQL (NOT on the VPS) ----
# host.docker.internal WILL FAIL — MySQL is remote on Hostinger DB servers.
#
# 1) hPanel → Databases → copy exact MySQL hostname (often NOT localhost)
#    examples: srv1234.hstgr.io  OR  mysql.hostinger.com  OR  the host shown in phpMyAdmin
# 2) hPanel → Databases → Remote MySQL → allow VPS IP: 200.97.171.119
# 3) Use that hostname below:
#
DATABASE_URL=mysql+pymysql://u808821982_Malwa_crm:YOUR_DB_PASSWORD@PUT_HPANEL_MYSQL_HOST_HERE:3306/u808821982_Malwa_crm?charset=utf8mb4

JWT_SECRET=CHANGE_ME_TO_LONG_RANDOM_SECRET_32CHARS_MIN
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
CORS_ORIGINS=https://crm.malwatrolley.com,http://localhost,http://200.97.171.119:8010

SEED_ADMIN_EMAIL=admin@malwatrolley.com
SEED_ADMIN_PASSWORD=Malwa#8224
SEED_ADMIN_NAME=Malwa Admin

# ---- Only if using docker-compose.mysql.yml (MySQL inside Docker) ----
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=malwa_crm
MYSQL_USER=crm_user
MYSQL_PASSWORD=changeme
