{
  "name": "malwa-crm",
  "productName": "Malwa CRM",
  "version": "2.0.0",
  "type": "module",
  "description": "Malwa Trolley CRM - Windows Desktop Application for Business Management",
  "author": {
    "name": "Malwa Trolley",
    "email": "malwatrolley@gmail.com"
  },
  "main": "electron/main.cjs",
  "private": true,
  "homepage": "./",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:deploy": "vite build && node scripts/prepare-frontend-deploy.mjs",
    "build:deploy:frontend": "vite build && node scripts/prepare-frontend-deploy.mjs",
    "build:deploy:backend": "node scripts/prepare-backend-deploy.mjs",
    "build:deploy:all": "npm run build:deploy:frontend && npm run build:deploy:backend",
    "preview": "vite preview",
    "web:dev": "vite",
    "web:build": "vite build",
    "api:dev": "cd backend && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder --win",
    "build:win": "npm run build && electron-builder --win --x64",
    "build:win64": "npm run build && electron-builder --win --x64",
    "build:win32": "npm run build && electron-builder --win --ia32",
    "build:portable": "npm run build && electron-builder --win portable",
    "build:installer": "npm run build && electron-builder --win nsis --x64",
    "build:full": "npm run build && electron-builder --win nsis portable zip --x64 --ia32",
    "build:production": "npm run clean && npm run build && electron-builder --win --x64 --publish=never",
    "installer": "powershell -ExecutionPolicy Bypass -File build-windows-installer.ps1",
    "quick-build": "powershell -ExecutionPolicy Bypass -File quick-build.ps1",
    "dist": "npm run build && electron-builder --win --publish=never",
    "dist:all": "npm run build && electron-builder --win --x64 --ia32",
    "release": "npm run build:production && echo Installers ready in release/ folder",
    "clean": "rimraf dist release node_modules/.vite",
    "clean:all": "rimraf dist release node_modules package-lock.json",
    "fresh-install": "npm run clean:all && npm install",
    "audit-fix": "npm audit fix",
    "setup:windows": "powershell -ExecutionPolicy Bypass -File .\\windows-setup.ps1"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dexie": "^4.2.1",
    "dexie-react-hooks": "^4.2.0",
    "framer-motion": "^11.0.8",
    "html2canvas": "^1.4.1",
    "jspdf": "^3.0.3",
    "jspdf-autotable": "^5.0.2",
    "lucide-react": "^0.344.0",
    "mysql2": "^3.22.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.2",
    "recharts": "^2.12.2",
    "sonner": "^1.4.3",
    "uuid": "^9.0.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^39.2.3",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.35",
    "rimraf": "^5.0.5",
    "tailwindcss": "^3.4.1",
    "vite": "^7.2.4",
    "wait-on": "^7.2.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "CRM",
    "business-management",
    "desktop-app",
    "electron",
    "react",
    "windows",
    "offline-first",
    "local-database"
  ]
}
